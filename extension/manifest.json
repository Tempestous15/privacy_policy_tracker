{
  "manifest_version": 3,
  "name": "ClipPri",
  "version": "2.0.1",
  "description": "Instant, on-device privacy policy scanning -- red flags, ToS;DR ratings, and an on-device AI summary. No account, no server.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background_entry.js",
    "scripts": [
      "background.js",
      "tracker_radar_score.js",
      "tracker_capture_background.js"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClipPri"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "clippri@example.invalid",
      "strict_min_version": "109.0"
    }
  }
}
