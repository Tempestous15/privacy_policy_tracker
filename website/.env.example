# Copy this file to .env (same folder as manage.py) and fill in your real key.
# .env is already gitignored -- never commit real API keys.
ANTHROPIC_API_KEY=your-api-key-here

# --- Production-only settings (leave unset for local dev) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
#DJANGO_SECRET_KEY=
#DJANGO_DEBUG=false
# Comma-separated hostnames/IPs the site is served from:
#DJANGO_ALLOWED_HOSTS=myapp.example.com,3.90.12.34
# Comma-separated origins (with scheme) allowed for CSRF-protected POSTs:
#DJANGO_CSRF_TRUSTED_ORIGINS=https://myapp.example.com
# Absolute path for the SQLite file, outside the repo checkout:
#DJANGO_DB_PATH=/var/lib/privacy-tracker/db.sqlite3
# Set to true once HTTPS (certbot) is working, to force HTTP -> HTTPS:
#DJANGO_SSL_REDIRECT=true
