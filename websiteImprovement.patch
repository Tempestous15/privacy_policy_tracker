+      "\\bmay retain\\b[^.]{0,30}\\bafter (?:deletion|account closure)\\b",
+      "\\bresidual copies\\b",
+      "\\bbackup (?:systems|copies)\\b[^.]{0,30}\\bretain\\w*\\b"
+    ]
+  },
+  {
+    "id": "tracking_profiling",
+    "label": "Extensive tracking / behavioral profiling",
+    "severity": "medium",
+    "patterns": [
